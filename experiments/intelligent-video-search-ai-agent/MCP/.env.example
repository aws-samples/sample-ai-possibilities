# AWS Configuration
AWS_REGION=us-east-1
# AWS credentials can be set here or use AWS CLI/IAM roles (preferred option)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# OpenSearch Configuration
OPENSEARCH_ENDPOINT=your-domain.us-east-1.aoss.amazonaws.com
OPENSEARCH_INDEX=video-insights-collection

# MCP Server Configuration
MCP_HOST=localhost
MCP_PORT=8009

# Bedrock Model Configuration
COHERE_MODEL_ID=cohere.embed-english-v3

# Logging Configuration
# LOG_LEVEL=INFO