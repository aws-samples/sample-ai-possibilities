# AgentCore config TEMPLATE. deploy-all.sh substitutes ${AWS_ACCOUNT_ID}/${AWS_DEFAULT_REGION} and
# writes the real .bedrock_agentcore.yaml into a build staging dir (never committed).
default_agent: ship_support_agent
agents:
  ship_support_agent:
    name: ship_support_agent
    entrypoint: src/main.py
    deployment_type: direct_code_deploy
    runtime_type: PYTHON_3_10
    platform: linux/arm64
    container_runtime: null
    source_path: .
    aws:
      account: "${AWS_ACCOUNT_ID}"
      execution_role_auto_create: true
      region: ${AWS_DEFAULT_REGION}
      ecr_repository: null
      ecr_auto_create: false
      s3_auto_create: true
      # PUBLIC network mode: a new AgentCore runtime cold-inits fastest with public networking, and
      # these agents hold no secrets (NO_MEMORY) — they are only invokable when the caller's IAM
      # allows it. Switch to a VPC configuration if your deployment requires private networking.
      network_configuration:
        network_mode: PUBLIC
      protocol_configuration:
        server_protocol: HTTP
      observability:
        enabled: true
      lifecycle_configuration:
        idle_runtime_session_timeout: null
        max_lifetime: null
    memory:
      mode: NO_MEMORY
    identity:
      credential_providers: []
      workload: null
    aws_jwt:
      enabled: false
      audiences: []
      signing_algorithm: ES384
      issuer_url: null
      duration_seconds: 300
    request_header_configuration: null
    oauth_configuration: null
    api_key_env_var_name: null
    api_key_credential_provider_name: null
    is_generated_by_agentcore_create: false
